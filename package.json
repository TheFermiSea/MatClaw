{
  "name": "matclaw",
  "version": "2026.3.17",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp src/web/dashboard.html dist/web/",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/wizard.ts",
    "setup:step": "tsx setup/index.ts",
    "setup:api": "tsx setup/index.ts --step configure-api",
    "auth": "tsx src/whatsapp-auth.ts",
    "auth:feishu": "tsx src/feishu-auth.ts",
    "auth:dingtalk": "tsx src/dingtalk-auth.ts",
    "auth:telegram": "tsx src/telegram-auth.ts",
    "auth:discord": "tsx src/discord-auth.ts",
    "auth:slack": "tsx src/slack-auth.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@types/qrcode-terminal": "^0.12.0",
    "@types/ws": "^8.18.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^11.8.1",
    "cron-parser": "^5.5.0",
    "dingtalk-stream": "^2.1.4",
    "googleapis": "^144.0.0",
    "ora": "^9.3.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
