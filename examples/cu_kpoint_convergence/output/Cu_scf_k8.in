&CONTROL
    calculation = 'scf'
    restart_mode = 'from_scratch'
    pseudo_dir = './'
    outdir = './tmp'
    prefix = 'cu'
    tprnfor = .false.
    tstress = .false.
    verbosity = 'low'
    disk_io = 'low'
    wf_collect = .false.
/
&SYSTEM
    ibrav = 0
    celldm(1) = 6.8313626631542945
    nat = 1
    ntyp = 1
    ecutwfc = 45.0
    ecutrho = 236.0
    occupations = 'smearing'
    smearing = 'mv'
    degauss = 0.02
/
&ELECTRONS
    electron_maxstep = 100
    conv_thr = 1.0d-8
    mixing_beta = 0.7
/
ATOMIC_SPECIES
 Cu  63.546  Cu.pbe-dn-kjpaw_psl.1.0.0.UPF
ATOMIC_POSITIONS crystal
 Cu  0.000000000  0.000000000  0.000000000
CELL_PARAMETERS alat
  0.000000000  0.500000000  0.500000000
  0.500000000  0.000000000  0.500000000
  0.500000000  0.500000000  0.000000000
K_POINTS automatic
 8 8 8 0 0 0
