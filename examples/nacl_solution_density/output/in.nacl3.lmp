# NaCl aqueous solution density at 298 K, 1 atm
# SPC/E water + Joung-Cheatham (JPCB 2008)

units           real
atom_style      full
boundary        p p p

read_data       nacl2.data

# ---------------------------------------------------------------
# Stage 0: Soft-core push-off to remove overlaps
# ---------------------------------------------------------------
pair_style      soft 5.0
pair_coeff      * *  100.0  3.0
kspace_style    none
bond_style      harmonic
bond_coeff   1  100.0  1.0
angle_style     harmonic
angle_coeff  1  50.0  109.47

neighbor        3.0 bin
neigh_modify    every 1 delay 0 check yes

minimize 1.0e-3 1.0e-5 2000 20000

# ---------------------------------------------------------------
# Stage 1: Switch to real force field
# ---------------------------------------------------------------
pair_style      lj/cut/coul/long 10.0
kspace_style    pppm 1.0e-5

pair_coeff 1 1  0.15535  3.16600   # O-O  (SPC/E)
pair_coeff 2 2  0.00000  1.00000   # H-H
pair_coeff 3 3  0.35260  2.15953   # Na-Na (Joung-Cheatham/SPC/E)
pair_coeff 4 4  0.01279  4.83052   # Cl-Cl (Joung-Cheatham/SPC/E)
pair_modify    mix arithmetic

bond_coeff   1  1000.0  1.0
angle_coeff  1  1000.0  109.47

# Minimize again with real FF (no SHAKE, just harmonic to relax bonds)
minimize 1.0e-4 1.0e-6 1000 10000

# ---------------------------------------------------------------
# SHAKE for rigid SPC/E
# ---------------------------------------------------------------
fix shake_water all shake 1.0e-4 200 0 b 1 a 1

# ---------------------------------------------------------------
# Stage 2: NVT warmup 10→298 K (small timestep)
# ---------------------------------------------------------------
velocity all create 10.0 12345 dist gaussian
fix nvt_warm all nvt temp 10.0 298.0 100.0
timestep 0.5
thermo 2000
thermo_style custom step temp press vol density
run 20000   # 10 ps
unfix nvt_warm

# ---------------------------------------------------------------
# Stage 3: NPT equilibration 298 K / 1 atm
# ---------------------------------------------------------------
fix npt_equil all npt temp 298.0 298.0 100.0 iso 1.0 1.0 1000.0
timestep 2.0
thermo 2000
thermo_style custom step temp press vol density
run 100000   # 200 ps
unfix npt_equil

# ---------------------------------------------------------------
# Stage 4: NPT production 298 K / 1 atm
# ---------------------------------------------------------------
fix npt_prod all npt temp 298.0 298.0 100.0 iso 1.0 1.0 1000.0
timestep 2.0
thermo 1000
thermo_style custom step temp press vol density

variable rho_gcc equal density
fix avg_density all ave/time 1000 5 5000 v_rho_gcc file density_prod.dat

run 200000   # 400 ps production

print "DONE"
