mass            1 26.982

pair_style      eam/alloy
pair_coeff      * * /usr/share/lammps/potentials/Al_zhou.eam.alloy Al
Reading eam/alloy potential file /usr/share/lammps/potentials/Al_zhou.eam.alloy with DATE: 2007-10-12

# Get box bounds
variable        zlo equal zlo
variable        zhi equal zhi
variable        zmid equal (zlo+zhi)/2

# Define lower (solid) and upper (liquid) regions
region          lower block INF INF INF INF ${zlo} ${zmid}
region          lower block INF INF INF INF -0.63435449606424 ${zmid}
region          lower block INF INF INF INF -0.63435449606424 40.4999999999993
region          upper block INF INF INF INF ${zmid} ${zhi}
region          upper block INF INF INF INF 40.4999999999993 ${zhi}
region          upper block INF INF INF INF 40.4999999999993 81.6343544960628
group           lower_atoms region lower
4010 atoms in group lower_atoms
group           upper_atoms region upper
3990 atoms in group upper_atoms

# Fix lower half, heat upper half to melt it
velocity        upper_atoms create 3000.0 54321 dist gaussian
fix             freeze lower_atoms setforce 0.0 0.0 0.0
fix             melt   upper_atoms nvt temp 3000 3000 0.05
thermo          200
thermo_style    custom step temp pe ke press
run             5000
