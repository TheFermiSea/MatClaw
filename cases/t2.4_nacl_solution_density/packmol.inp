# Packmol input for NaCl solution
tolerance 2.0
filetype xyz
output solution.xyz

# Water molecules
structure water.xyz
  number 1000
  inside box -15.8 -15.8 -15.8 15.8 15.8 15.8
end structure

# Sodium ions
structure na.xyz
  number 18
  inside box -15.8 -15.8 -15.8 15.8 15.8 15.8
end structure

# Chloride ions
structure cl.xyz
  number 18
  inside box -15.8 -15.8 -15.8 15.8 15.8 15.8
end structure