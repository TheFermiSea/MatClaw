# LAMMPS heating simulation for aluminum melting point
# Using Zhou EAM potential
# Linear temperature ramp from 300K to 1500K

# Units
units metal

# Atom style
atom_style atomic

# Create box and lattice
lattice fcc 4.041
region box block 0 6 0 6 0 6
create_box 1 box
create_atoms 1 box

# Define potential
pair_style eam/alloy
pair_coeff * * /usr/share/lammps/potentials/Al_zhou.eam.alloy Al

# Velocity initialization
velocity all create 300.0 12345 rot yes dist gaussian

# Neighbor settings
neighbor 2.0 bin
neigh_modify delay 0 every 1 check yes

# Thermodynamic output
thermo 100
thermo_style custom step temp pe ke etotal press density vol

# Minimization
minimize 1e-10 1e-10 1000 1000

# Equilibration at 300K and 1 atm (NPT)
reset_timestep 0
timestep 0.001
fix 1 all npt temp 300 300 0.1 iso 0 0 1.0
run 5000
unfix 1

# Heating run: linear temperature ramp from 300K to 1500K over 100 ps
fix 2 all npt temp 300 1500 0.1 iso 0 0 1.0

# Compute potential energy per atom
compute peatom all pe/atom
compute pe all reduce sum c_peatom
variable peatom equal c_pe/atoms
variable density equal density

# Output temperature, peatom, density every 10 steps
fix 3 all print 10 "${step} ${temp} ${peatom} ${density}" file heating.out screen no title "# Step Temp PEatom Density"

# Run heating for 100000 steps (100 ps)
run 100000

# Write final configuration
write_data final_heating.data
write_dump all atom final_heating.dump

print "Heating simulation completed"