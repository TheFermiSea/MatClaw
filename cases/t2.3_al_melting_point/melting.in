# LAMMPS input script for aluminum melting point calculation
# Using Zhou EAM potential

# Units
units metal

# Atom style
atom_style atomic

# Create box and lattice
lattice fcc 4.041
region box block 0 4 0 4 0 4
create_box 1 box
create_atoms 1 box

# Define potential
pair_style eam/alloy
pair_coeff * * /usr/share/lammps/potentials/Al_zhou.eam.alloy Al

# Velocity initialization
velocity all create 300.0 12345 rot yes dist gaussian

# Neighbor settings
neighbor 2.0 bin
neigh_modify delay 0 every 1 check yes

# Thermodynamic output
thermo 100
thermo_style custom step temp pe ke etotal press density vol

# Minimization
minimize 1e-10 1e-10 1000 1000

# Equilibration at 300K and 1 atm (NPT)
reset_timestep 0
timestep 0.001
fix 1 all npt temp 300 300 0.1 iso 0 0 1.0
run 5000
unfix 1

# Heating run: gradually increase temperature from 300K to 1500K
# We'll use NPT ensemble with temperature ramping
variable T_start equal 300
variable T_end equal 1500
variable T_rate equal 0.1 # K/ps
variable run_steps equal 10000
variable T_increment equal (v_T_end - v_T_start) / v_run_steps

# Set up temperature ramp
variable t_temp equal v_T_start + step*${T_increment}
fix 2 all npt temp ${T_start} ${T_end} 0.1 iso 0 0 1.0

# Compute potential energy per atom
compute peatom all pe/atom
compute pe all reduce sum c_peatom
variable peatom equal c_pe/atoms

# Compute density
variable density equal density

# Output for monitoring
thermo 50
thermo_style custom step temp v_peatom v_density press vol

# Run heating
run ${run_steps}

# Write final configuration
write_data final.data
write_dump all atom final.dump