# LAMMPS simulation at multiple temperatures
# Using Zhou EAM potential
# Read equilibrated configuration

# Units
units metal

# Atom style
atom_style atomic

# Read data file
read_data final.data

# Define potential
pair_style eam/alloy
pair_coeff * * /usr/share/lammps/potentials/Al_zhou.eam.alloy Al

# Neighbor settings
neighbor 3.0 bin
neigh_modify delay 5 every 1 check yes

# Thermodynamic output
thermo 100
thermo_style custom step temp pe ke etotal press density vol

# Compute potential energy per atom
compute peatom all pe/atom
compute pe all reduce sum c_peatom
variable peatom equal c_pe/atoms

# Define temperature list
variable T loop 300 600 900 1200

# Loop over temperatures
label loop
variable Tcur equal ${T}
print "Running temperature ${Tcur}"

# Velocity initialization at this temperature
velocity all create ${Tcur} 12345 rot yes dist gaussian

# NVT equilibration
fix 1 all nvt temp ${Tcur} ${Tcur} 0.5
run 3000
unfix 1

# Production run with averaging
fix 2 all nvt temp ${Tcur} ${Tcur} 0.5
fix 3 all ave/time 100 10 1000 c_peatom file ave_${Tcur}.out
run 2000
unfix 2
unfix 3

# Output final PE
variable finalpeatom equal c_pe/atoms
print "Temperature ${Tcur}: PE per atom = ${finalpeatom} eV"

next T
jump SELF loop

print "All temperatures completed"