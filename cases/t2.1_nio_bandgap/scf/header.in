&control
    calculation = 'bands'
    restart_mode = 'restart'
    prefix = 'nio'
    pseudo_dir = '../pseudo'
    outdir = './tmp'
    tprnfor = .false.
    tstress = .false.
    verbosity = 'high'
/
&system
    ibrav = 2
    celldm(1) = 7.88016108
    nat = 2
    ntyp = 2
    ecutwfc = 75.0
    ecutrho = 476.0
    occupations = 'smearing'
    smearing = 'mv'
    degauss = 0.01
    nspin = 1
    nbnd = 30
/
&electrons
    conv_thr = 1.0d-8
    mixing_beta = 0.7
    electron_maxstep = 100
/
&ions
/
&cell
/
ATOMIC_SPECIES
 Ni 58.6934 Ni.pbe-spn-kjpaw_psl.1.0.0.UPF
 O  15.9994 O.pbe-n-kjpaw_psl.1.0.0.UPF
ATOMIC_POSITIONS crystal
 Ni 0.0 0.0 0.0
 O  0.5 0.5 0.5
K_POINTS crystal
